# ══════════════════════════════════════════════════════════════
# .env.docker.example — Dùng khi chạy Docker Compose (dev)
# ══════════════════════════════════════════════════════════════
# Copy: cp .env.docker.example .env.docker
# Áp dụng: docker compose up -d  (docker-compose.yml)
#
# Hosts = tên service trong Docker network:
#   postgres, redis, emqx

# ──────────────────────────────────────────────
# APPLICATION
# ──────────────────────────────────────────────
APP_ENV="development"
APP_NAME="aurathink"
APP_DEBUG=true
APP_LOG_LEVEL="debug"

# ──────────────────────────────────────────────
# HTTP SERVER
# ──────────────────────────────────────────────
HTTP_HOST="0.0.0.0"
HTTP_PORT=3001
HTTP_VERSIONING_ENABLE=true
HTTP_VERSION=1
APP_CORS_ORIGINS="*"

# ──────────────────────────────────────────────
# MICROSERVICE PORTS
# ──────────────────────────────────────────────
SOCKET_GATEWAY_PORT=3002
IOT_GATEWAY_PORT=3003
WORKER_SERVICE_PORT=3004

# ──────────────────────────────────────────────
# AUTHENTICATION & JWT
# ──────────────────────────────────────────────
AUTH_ACCESS_TOKEN_SECRET="docker-dev-access-secret"
AUTH_REFRESH_TOKEN_SECRET="docker-dev-refresh-secret"
AUTH_ACCESS_TOKEN_EXP="7d"
AUTH_REFRESH_TOKEN_EXP="30d"

# ──────────────────────────────────────────────
# DATABASE — host = "postgres" (service name)
# ──────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=master123
POSTGRES_DB=aurathink
DATABASE_URL="postgresql://postgres:master123@postgres:5432/aurathink?schema=public"

# ──────────────────────────────────────────────
# REDIS — host = "redis" (service name)
# ──────────────────────────────────────────────
REDIS_HOST="redis"
REDIS_PORT=6379
REDIS_USERNAME=default
REDIS_PASSWORD=""
REDIS_ENABLE_TLS=false

# ──────────────────────────────────────────────
# MQTT (EMQX) — host = "emqx" (service name)
# ──────────────────────────────────────────────
MQTT_HOST=mqtt://emqx
MQTT_PORT=1883
MQTT_USER=admin
MQTT_PASS=public

# ──────────────────────────────────────────────
# EMQX Dashboard
# ──────────────────────────────────────────────
EMQX_DASHBOARD_USER=admin
EMQX_DASHBOARD_PASS=admin123

# ──────────────────────────────────────────────
# MAIL (SMTP)
# ──────────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FROM="Smart Home <your-email@gmail.com>"

# ──────────────────────────────────────────────
# SENTRY — tắt khi dev
# ──────────────────────────────────────────────
SENTRY_DSN=""

# ──────────────────────────────────────────────
# ADMIN SEED
# ──────────────────────────────────────────────
ADMIN_EMAIL=admin@localhost.com
ADMIN_PASSWORD=Admin@Docker123!

# ──────────────────────────────────────────────
# APP VERSION & SSL
# ──────────────────────────────────────────────
APP_VERSION=dev
SSL_CERT_PATH=./deploy/docker/ssl
