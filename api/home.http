# ==========================================
# HOME – Nhà, Tầng (Floor), Phòng (Room)
# ==========================================
# Chạy "Login User" trước để có accessToken
@baseUrl = https://sensasmart.ddns.net/api/v1
@userEmail = cursor2@test.com
@userPassword = Password@123!
# Điền homeId/floorId/roomId sau khi tạo hoặc lấy từ response (ví dụ getHomes)
@homeId = 00000000-0000-0000-0000-000000000000
@floorId = 00000000-0000-0000-0000-000000000000
@roomId = 00000000-0000-0000-0000-000000000000

###
# Login User (chạy trước)
# @name loginUser
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
    "identifier": "{{userEmail}}",
    "password": "{{userPassword}}"
}

###
# --- HOMES ---

# Lấy danh sách nhà của user
# @name getHomes
GET {{baseUrl}}/homes
Authorization: Bearer {{loginUser.response.body.data.accessToken}}

###
# Tạo nhà mới
POST {{baseUrl}}/homes
Authorization: Bearer {{loginUser.response.body.data.accessToken}}
Content-Type: application/json

{
    "name": "Nhà của tôi",
    "latitude": 21.0285,
    "longitude": 105.8542,
    "radius": 100
}

###
# Cập nhật nhà
PATCH {{baseUrl}}/homes/{{homeId}}
Authorization: Bearer {{loginUser.response.body.data.accessToken}}
Content-Type: application/json

{
    "name": "Nhà chính",
    "radius": 150
}

###
# Lấy danh sách thành viên trong nhà
GET {{baseUrl}}/homes/{{homeId}}/members
Authorization: Bearer {{loginUser.response.body.data.accessToken}}

###
# Thêm thành viên vào nhà (theo email hoặc userId)
POST {{baseUrl}}/homes/{{homeId}}/members
Authorization: Bearer {{loginUser.response.body.data.accessToken}}
Content-Type: application/json

{
    "email": "member@example.com",
    "role": "MEMBER"
}

###
# --- FLOORS ---

# Lấy danh sách tầng theo nhà
# @name getFloors
GET {{baseUrl}}/homes/{{homeId}}/floors
Authorization: Bearer {{loginUser.response.body.data.accessToken}}

###
# Tạo tầng trong nhà
POST {{baseUrl}}/homes/{{homeId}}/floors
Authorization: Bearer {{loginUser.response.body.data.accessToken}}
Content-Type: application/json

{
    "name": "Tầng 1",
    "sortOrder": 0
}

###
# Cập nhật tầng
PATCH {{baseUrl}}/homes/floors/{{floorId}}
Authorization: Bearer {{loginUser.response.body.data.accessToken}}
Content-Type: application/json

{
    "name": "Tầng trệt",
    "sortOrder": 1
}

###
# --- ROOMS ---

# Lấy danh sách phòng theo nhà (tất cả)
# @name getRoomsByHome
GET {{baseUrl}}/homes/{{homeId}}/rooms
Authorization: Bearer {{loginUser.response.body.data.accessToken}}

###
# Lấy danh sách phòng theo tầng
GET {{baseUrl}}/homes/{{homeId}}/floors/{{floorId}}/rooms
Authorization: Bearer {{loginUser.response.body.data.accessToken}}

###
# Tạo phòng trong nhà (có thể gán floorId)
POST {{baseUrl}}/homes/{{homeId}}/rooms
Authorization: Bearer {{loginUser.response.body.data.accessToken}}
Content-Type: application/json

{
    "name": "Phòng khách",
    "floorId": "{{floorId}}"
}

###
# Cập nhật phòng
PATCH {{baseUrl}}/homes/rooms/{{roomId}}
Authorization: Bearer {{loginUser.response.body.data.accessToken}}
Content-Type: application/json

{
    "name": "Phòng khách rộng"
}

###
# --- ACTIVITY TIMELINE (LỊCH SỬ HOẠT ĐỘNG TOÀN NHÀ) ---

# Lấy timeline hoạt động toàn bộ nhà (5 items gần nhất → cho popover home-screen)
GET {{baseUrl}}/homes/{{homeId}}/activity?page=1&limit=5
Authorization: Bearer {{loginUser.response.body.data.accessToken}}

###
# Lấy timeline hoạt động toàn bộ nhà (phân trang → cho detail screen)
GET {{baseUrl}}/homes/{{homeId}}/activity?page=1&limit=30
Authorization: Bearer {{loginUser.response.body.data.accessToken}}

###
# Lấy timeline hoạt động toàn bộ nhà (filter theo ngày)
GET {{baseUrl}}/homes/{{homeId}}/activity?page=1&limit=30&from=2026-03-01&to=2026-03-29
Authorization: Bearer {{loginUser.response.body.data.accessToken}}
