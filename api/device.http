# ==========================================
# DEVICE – Đăng ký thiết bị, danh sách, điều khiển
# ==========================================
# Chạy "Login User" trước để có accessToken
@baseUrl = https://aurathink.ddns.net/api/v1
@userEmail = vulewenlian942@gmail.com
@userPassword = Vu31101994@
@macAddress = AA:BB:CC:11:22:33
@deviceModelCode = 1001
@companyCode = BKTech
# deviceToken & deviceId: lấy từ GET /devices
@deviceToken = your-device-token-here
@deviceId = 00000000-0000-0000-0000-000000000000

###
# Login User (chạy trước)
# @name loginUser
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
    "identifier": "{{userEmail}}",
    "password": "{{userPassword}}"
}

###
# --- ĐĂNG KÝ & DANH SÁCH ---

# Đăng ký / claim thiết bị (identifier = MAC với MQTT)
POST {{baseUrl}}/devices/register
Authorization: Bearer {{loginUser.response.body.data.accessToken}}
Content-Type: application/json

{
    "identifier": "{{macAddress}}",
    "deviceCode": "{{deviceModelCode}}",
    "partnerCode": "{{companyCode}}",
    "protocol": "MQTT",
    "name": "Đèn Phòng Khách"
}

###
# Lấy danh sách thiết bị (phân trang)
# @name getDevices
GET {{baseUrl}}/devices?page=1&limit=10
Authorization: Bearer {{loginUser.response.body.data.accessToken}}

###
# Lấy chi tiết một thiết bị (theo id)
GET {{baseUrl}}/devices/{{getDevices.response.body.data.data[0].id}}
Authorization: Bearer {{loginUser.response.body.data.accessToken}}

###
# Siri Sync – Lấy tất cả devices + scenes cho Siri/Google Assistant
GET {{baseUrl}}/devices/siri-sync
Authorization: Bearer {{loginUser.response.body.data.accessToken}}

###
# --- ĐIỀU KHIỂN ---

# Set một entity (theo entityCode) – ví dụ shutter
POST {{baseUrl}}/devices/{{deviceToken}}/entities/main/setValue
Authorization: Bearer {{loginUser.response.body.data.accessToken}}
Content-Type: application/json

{
    "value": "OPEN"
}

###
# Set entity dạng BINARY (bật/tắt, khóa trẻ em...)
POST {{baseUrl}}/devices/{{deviceToken}}/entities/security_lock/setValue
Authorization: Bearer {{loginUser.response.body.data.accessToken}}
Content-Type: application/json

{
    "value": 1
}

###
# Set entity dạng CONFIG (object)
POST {{baseUrl}}/devices/{{deviceToken}}/entities/sys_config/setValue
Authorization: Bearer {{loginUser.response.body.data.accessToken}}
Content-Type: application/json

{
    "value": {
        "config": {
            "req_open_clicks": 5,
            "req_close_clicks": 5,
            "def_open_clicks": 1,
            "def_close_clicks": 1,
            "time_mode": 1,
            "start_time": "22:15",
            "end_time": "06:00"
        }
    }
}

###
# Set toàn bộ giá trị thiết bị (bulk)
POST {{baseUrl}}/devices/{{deviceToken}}/setValue
Authorization: Bearer {{loginUser.response.body.data.accessToken}}
Content-Type: application/json

{
    "value": {
        "shutter_main": "CLOSE",
        "security_lock": 0
    }
}
