{
  "name": "@sensa-smart/source",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "prepare": "husky",
    "postinstall": "prisma generate",
    "prebuild": "rimraf dist",
    "build": "nx run-many --target=build --all",
    "build:core-api": "nx build core-api",
    "build:iot-gateway": "nx build iot-gateway",
    "build:socket-gateway": "nx build socket-gateway",
    "build:worker-service": "nx build worker-service",
    "start": "node dist/apps/core-api/main",
    "dev": "dotenv -e .env.local -- nx run-many --target=serve --all --parallel",
    "dev:core-api": "dotenv -e .env.local -- nx serve core-api",
    "dev:iot-gateway": "dotenv -e .env.local -- nx serve iot-gateway",
    "dev:socket-gateway": "dotenv -e .env.local -- nx serve socket-gateway",
    "dev:worker-service": "dotenv -e .env.local -- nx serve worker-service",
    "generate": "dotenv -e .env.local -- prisma generate",
    "migrate": "dotenv -e .env.local -- prisma migrate dev",
    "migrate:deploy": "dotenv -e .env.local -- prisma migrate deploy",
    "migrate:prod": "dotenv -e .env.production -- prisma migrate deploy",
    "migrate:docker": "dotenv -e .env.docker -- prisma migrate deploy",
    "studio": "dotenv -e .env.local -- prisma studio",
    "seed:admin": "dotenv -e .env.local -- cross-env TS_NODE_PROJECT=apps/core-api/tsconfig.app.json ts-node --transpile-only -r tsconfig-paths/register apps/core-api/src/cli.ts seed:admin",
    "seed:admin:prod": "dotenv -e .env.production -- cross-env TS_NODE_PROJECT=apps/core-api/tsconfig.app.json ts-node --transpile-only -r tsconfig-paths/register apps/core-api/src/cli.ts seed:admin",
    "update:package": "npx npm-check-updates -u",
    "make-badges": "istanbul-badges-readme",
    "lint": "nx run-many --target=lint --all",
    "lint:fix": "nx run-many --target=lint --all --fix",
    "format": "prettier --write \"{apps,libs,test}/**/*.ts\"",
    "test": "nx run-many --target=test --all",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand"
  },
  "private": true,
  "dependencies": {
    "@faker-js/faker": "^10.3.0",
    "@nestjs-modules/mailer": "^2.0.2",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/cache-manager": "^3.0.1",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.0",
    "@nestjs/jwt": "^11.0.1",
    "@nestjs/microservices": "^11.1.13",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/platform-socket.io": "^11.1.13",
    "@nestjs/schedule": "^6.0.1",
    "@nestjs/swagger": "^11.2.2",
    "@nestjs/terminus": "^11.0.0",
    "@nestjs/throttler": "^6.4.0",
    "@nestjs/websockets": "^11.1.13",
    "@prisma/client": "6.19.2",
    "@sentry/node": "^10.25.0",
    "@sentry/tracing": "^7.120.4",
    "@socket.io/redis-adapter": "^8.3.0",
    "@types/express": "^5.0.5",
    "@types/ioredis": "^5.0.0",
    "argon2": "^0.44.0",
    "axios": "^1.6.0",
    "bullmq": "^5.67.3",
    "cache-manager": "^7.2.5",
    "cache-manager-ioredis": "^2.1.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "compression": "^1.8.1",
    "cron-parser": "^5.5.0",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "expo-server-sdk": "^6.1.0",
    "handlebars": "^4.7.8",
    "helmet": "^8.1.0",
    "ioredis": "^5.9.2",
    "jsonwebtoken": "^9.0.2",
    "lodash": "^4.17.21",
    "mqtt": "^5.15.0",
    "nestjs-command": "^3.1.5",
    "nestjs-i18n": "^10.5.1",
    "nestjs-pino": "^4.4.1",
    "nodemailer": "^8.0.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "pino": "^10.1.0",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.2",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.0",
    "serialport": "^13.0.0",
    "serialport-gsm": "^4.0.1",
    "socket.io": "^4.8.3",
    "ssh2": "^1.17.0",
    "swagger-ui-express": "^5.0.1"
