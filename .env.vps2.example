# ══════════════════════════════════════════════════════════════
# .env.vps2.example — VPS2 "Mặt tiền" (GĐ2)
# ══════════════════════════════════════════════════════════════
# Chạy: core-api, socket-gateway, emqx, nginx, haproxy
# DB/Redis trỏ về VPS1 qua Tailscale (100.117.220.15)
#
# ⚠️ Copy nội dung này vào GitHub Secret: VPS2_ENV
# ⚠️ THAY TẤT CẢ GIÁ TRỊ "change-me-*" TRƯỚC KHI DÙNG
# ⚠️ Các secret JWT, DB password... PHẢI GIỐNG VPS1

# ──────────────────────────────────────────────
# APPLICATION
# ──────────────────────────────────────────────
APP_ENV="production"
APP_NAME="aurathink"
APP_DEBUG=false
APP_LOG_LEVEL="warn"

# ──────────────────────────────────────────────
# HTTP SERVER
# ──────────────────────────────────────────────
HTTP_HOST="0.0.0.0"
HTTP_PORT=3001
HTTP_VERSIONING_ENABLE=true
HTTP_VERSION=1
APP_CORS_ORIGINS="https://aurathink.ddns.net"

# ──────────────────────────────────────────────
# MICROSERVICE PORTS
# ──────────────────────────────────────────────
SOCKET_GATEWAY_PORT=3002
IOT_GATEWAY_PORT=3003
WORKER_SERVICE_PORT=3004

# ──────────────────────────────────────────────
# AUTHENTICATION & JWT (PHẢI GIỐNG VPS1)
# ──────────────────────────────────────────────
AUTH_ACCESS_TOKEN_SECRET="change-me-use-openssl-rand-base64-32"
AUTH_REFRESH_TOKEN_SECRET="change-me-use-openssl-rand-base64-32"
AUTH_ACCESS_TOKEN_EXP="1d"
AUTH_REFRESH_TOKEN_EXP="7d"

# ──────────────────────────────────────────────
# DATABASE — REMOTE (VPS1 qua Tailscale)
# ⚠️ Password phải giống POSTGRES_PASSWORD của VPS1
# ──────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong-db-password
POSTGRES_DB=aurathink
DATABASE_URL="postgresql://postgres:change-me-strong-db-password@100.117.220.15:5432/aurathink?schema=public"

# ──────────────────────────────────────────────
# REDIS — REMOTE (VPS1 qua Tailscale)
# ⚠️ Password phải giống REDIS_PASSWORD của VPS1
# ──────────────────────────────────────────────
REDIS_HOST="100.117.220.15"
REDIS_PORT=6379
REDIS_USERNAME=default
REDIS_PASSWORD="change-me-redis-password"
REDIS_ENABLE_TLS=false

# ──────────────────────────────────────────────
# MQTT (EMQX) — LOCAL (emqx node trên VPS2)
# ──────────────────────────────────────────────
MQTT_HOST=mqtt://localhost
MQTT_PORT=1883
MQTT_USER=smarthome-server
MQTT_PASS=change-me-mqtt-password

# ──────────────────────────────────────────────
# EMQX — Node name = Tailscale IP của VPS2
# ──────────────────────────────────────────────
EMQX_NODE_NAME=emqx@100.85.73.41
EMQX_DASHBOARD_USER=admin
EMQX_DASHBOARD_PASS=change-me-dashboard-password

# ──────────────────────────────────────────────
# MAIL (SMTP)
# ──────────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FROM="Smart Home Support <your-email@gmail.com>"

# ──────────────────────────────────────────────
# SSL & MISC
# ──────────────────────────────────────────────
SSL_CERT_PATH=./deploy/docker/ssl
SENTRY_DSN=""
ADMIN_EMAIL=admin@your-domain.com
ADMIN_PASSWORD=change-me-admin-password
APP_VERSION=latest
