# ══════════════════════════════════════════════
# EURO SMART SERVER - ENVIRONMENT CONFIGURATION
# ══════════════════════════════════════════════
# Copy this file to .env and update the values according to your setup
# DO NOT commit actual credentials to version control

# ──────────────────────────────────────────────
# 1. APPLICATION
# ──────────────────────────────────────────────
APP_ENV="local"            # local | staging | production
APP_NAME="eurosmart"
APP_DEBUG=true
APP_LOG_LEVEL="debug"      # debug | info | warn | error

# ──────────────────────────────────────────────
# 2. HTTP SERVER
# ──────────────────────────────────────────────
HTTP_HOST="0.0.0.0"
HTTP_PORT=3001
HTTP_VERSIONING_ENABLE=true
HTTP_VERSION=1

# CORS Origins - comma separated list of allowed origins
APP_CORS_ORIGINS="*"

# ──────────────────────────────────────────────
# 3. MICROSERVICE PORTS
# ──────────────────────────────────────────────
SOCKET_GATEWAY_PORT=3002
IOT_GATEWAY_PORT=3003
WORKER_SERVICE_PORT=3004

# ──────────────────────────────────────────────
# 4. AUTHENTICATION & JWT
# ──────────────────────────────────────────────
# Generate strong random secrets: openssl rand -base64 32
AUTH_ACCESS_TOKEN_SECRET="change-me-access-token-secret"
AUTH_REFRESH_TOKEN_SECRET="change-me-refresh-token-secret"
AUTH_ACCESS_TOKEN_EXP="1d"
AUTH_REFRESH_TOKEN_EXP="7d"

# ──────────────────────────────────────────────
# 5. DATABASE (PostgreSQL)
# ──────────────────────────────────────────────
# Format: postgresql://username:password@host:port/database?schema=public
DATABASE_URL="postgresql://postgres:password@localhost:5432/eurosmart?schema=public"

# ──────────────────────────────────────────────
# 6. REDIS
# ──────────────────────────────────────────────
REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_USERNAME=default
REDIS_PASSWORD=""
REDIS_ENABLE_TLS=false

# ──────────────────────────────────────────────
# 7. MQTT (EMQX)
# ──────────────────────────────────────────────
MQTT_HOST=mqtt://localhost
MQTT_PORT=1883
MQTT_USER=admin
MQTT_PASS=public

# ──────────────────────────────────────────────
# 8. MAIL (SMTP)
# ──────────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FROM="Smart Home Support <your-email@gmail.com>"

# ──────────────────────────────────────────────
# 9. ERROR TRACKING (Sentry)
# ──────────────────────────────────────────────
SENTRY_DSN=""

# ──────────────────────────────────────────────
# 10. MCP (Model Context Protocol)
# ──────────────────────────────────────────────
MCP_SERVER_NAME="nestjs-starter-mcp"
MCP_SERVER_VERSION="1.0.0"
MCP_LOG_LEVEL="debug"

# ──────────────────────────────────────────────
# 11. ADMIN SEED
# ──────────────────────────────────────────────
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMe123!
