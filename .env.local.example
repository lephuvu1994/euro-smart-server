# ══════════════════════════════════════════════════════════════
# .env.local.example — Dùng khi chạy LOCAL (ngoài Docker)
# ══════════════════════════════════════════════════════════════
# Copy: cp .env.local.example .env.local
# Áp dụng: yarn dev, yarn seed:admin, yarn migrate, yarn studio
#
# Yêu cầu: PostgreSQL, Redis, EMQX đã chạy trên localhost
#   Nhanh nhất: docker compose up postgres redis emqx -d

# ──────────────────────────────────────────────
# APPLICATION
# ──────────────────────────────────────────────
APP_ENV="local"
APP_NAME="sensa-smart"
APP_DEBUG=true
APP_LOG_LEVEL="debug"

# ──────────────────────────────────────────────
# HTTP SERVER
# ──────────────────────────────────────────────
HTTP_HOST="0.0.0.0"
HTTP_PORT=3001
HTTP_VERSIONING_ENABLE=true
HTTP_VERSION=1
APP_CORS_ORIGINS="*"

# ──────────────────────────────────────────────
# MICROSERVICE PORTS
# ──────────────────────────────────────────────
SOCKET_GATEWAY_PORT=3002
IOT_GATEWAY_PORT=3003
WORKER_SERVICE_PORT=3004

# ──────────────────────────────────────────────
# AUTHENTICATION & JWT
# ──────────────────────────────────────────────
AUTH_ACCESS_TOKEN_SECRET="local-dev-access-secret"
AUTH_REFRESH_TOKEN_SECRET="local-dev-refresh-secret"
AUTH_ACCESS_TOKEN_EXP="7d"
AUTH_REFRESH_TOKEN_EXP="30d"

# ──────────────────────────────────────────────
# DATABASE — host = localhost
# ──────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=master123
POSTGRES_DB=sensa_smart
DATABASE_URL="postgresql://postgres:master123@localhost:5432/sensa_smart?schema=public"

# ──────────────────────────────────────────────
# REDIS — host = localhost
# ──────────────────────────────────────────────
REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_USERNAME=default
REDIS_PASSWORD=""
REDIS_ENABLE_TLS=false

# ──────────────────────────────────────────────
# MQTT (EMQX) — host = localhost
# ──────────────────────────────────────────────
MQTT_HOST=mqtt://localhost
MQTT_PORT=1883
MQTT_USER=admin
MQTT_PASS=public
APP_MQTT_SECRET="local-dev-strong-app-mqtt-secret"
MQTT_WSS_URL="ws://localhost:1883/mqtt"

# ──────────────────────────────────────────────
# EMQX Dashboard
# ──────────────────────────────────────────────
EMQX_DASHBOARD_USER=admin
EMQX_DASHBOARD_PASS=admin123

# ──────────────────────────────────────────────
# MAIL (SMTP) — tuỳ chọn cho local
# ──────────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FROM="Smart Home <your-email@gmail.com>"

# ──────────────────────────────────────────────
# SENTRY — tắt ở local
# ──────────────────────────────────────────────
SENTRY_DSN=""

# ──────────────────────────────────────────────
# ADMIN SEED
# ──────────────────────────────────────────────
ADMIN_EMAIL=admin@localhost.com
ADMIN_PASSWORD=Admin@Local123!

# ──────────────────────────────────────────────
# APP VERSION
# ──────────────────────────────────────────────
APP_VERSION=dev
# ──────────────────────────────────────────────
# SYSTEM MONITORING & ALERTING
# ──────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_IDS=""
ALERT_EMAILS="admin@localhost.com"

# ──────────────────────────────────────────────
# DAILY AUTOMATED BACKUP (Cloudflare R2 / S3)
# ──────────────────────────────────────────────
S3_BUCKET="sensa-smart-backups"
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_REGION="auto"
S3_ENDPOINT=""

# ──────────────────────────────────────────────
# MCP & AI AGENT
# ──────────────────────────────────────────────
GEMINI_API_KEY=""
