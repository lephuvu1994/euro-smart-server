# ══════════════════════════════════════════════
# AURATHINK SERVER - ENVIRONMENT CONFIGURATION
# ══════════════════════════════════════════════
# Copy file này thành .env và điền giá trị thật
# KHÔNG commit .env vào Git
#
# Tạo secret ngẫu nhiên:
#   openssl rand -base64 32

# ──────────────────────────────────────────────
# 1. APPLICATION
# ──────────────────────────────────────────────
APP_ENV="production"         # local | staging | production
APP_NAME="sensa-smart"
APP_DEBUG=false
APP_LOG_LEVEL="info"         # debug | info | warn | error

# ──────────────────────────────────────────────
# 2. HTTP SERVER
# ──────────────────────────────────────────────
HTTP_HOST="0.0.0.0"
HTTP_PORT=3001
HTTP_VERSIONING_ENABLE=true
HTTP_VERSION=1

# CORS Origins — thay * bằng domain thật trong production
APP_CORS_ORIGINS="https://your-domain.com,https://app.your-domain.com"

# ──────────────────────────────────────────────
# 3. MICROSERVICE PORTS
# ──────────────────────────────────────────────
SOCKET_GATEWAY_PORT=3002
IOT_GATEWAY_PORT=3003
WORKER_SERVICE_PORT=3004

# ──────────────────────────────────────────────
# 4. AUTHENTICATION & JWT
# ──────────────────────────────────────────────
# Tạo: openssl rand -base64 32
AUTH_ACCESS_TOKEN_SECRET="change-me-use-openssl-rand-base64-32"
AUTH_REFRESH_TOKEN_SECRET="change-me-use-openssl-rand-base64-32"
AUTH_ACCESS_TOKEN_EXP="1d"
AUTH_REFRESH_TOKEN_EXP="7d"

# ──────────────────────────────────────────────
# 5. DATABASE (PostgreSQL)
# ──────────────────────────────────────────────
# ⚠️ Trong Docker: host = tên service = "postgres"
# Local dev: host = "localhost"
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=sensa_smart

# DATABASE_URL được override trong docker-compose (dùng service name)
# Chỉ cần set nếu chạy ngoài Docker:
DATABASE_URL="postgresql://postgres:change-me-strong-password@localhost:5432/sensa_smart?schema=public"

# ──────────────────────────────────────────────
# 6. REDIS
# ──────────────────────────────────────────────
# ⚠️ Trong Docker: REDIS_HOST = "redis" (tên service)
REDIS_HOST="redis"
REDIS_PORT=6379
REDIS_USERNAME=default
REDIS_PASSWORD="change-me-redis-password"
REDIS_ENABLE_TLS=false

# ──────────────────────────────────────────────
# 7. MQTT (EMQX)
# ──────────────────────────────────────────────
# ⚠️ Trong Docker: MQTT_HOST = "mqtt://emqx" (tên service)
MQTT_HOST=mqtt://emqx
MQTT_PORT=1883
MQTT_USER=smarthome-server
MQTT_PASS=change-me-mqtt-password
APP_MQTT_SECRET="change-me-strong-app-mqtt-secret"
MQTT_WSS_URL="wss://sensasmart.ddns.net/mqtt"

# ──────────────────────────────────────────────
# 8. EMQX Dashboard
# ──────────────────────────────────────────────
EMQX_DASHBOARD_USER=admin
EMQX_DASHBOARD_PASS=change-me-dashboard-password

# ──────────────────────────────────────────────
# 9. MAIL (SMTP)
# ──────────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FROM="Smart Home Support <your-email@gmail.com>"

# ──────────────────────────────────────────────
# 10. SSL
# ──────────────────────────────────────────────
# Đường dẫn thư mục chứa fullchain.pem + privkey.pem
SSL_CERT_PATH=./deploy/docker/ssl

# ──────────────────────────────────────────────
# 11. ERROR TRACKING (Sentry) — tuỳ chọn
# ──────────────────────────────────────────────
SENTRY_DSN=""

# ──────────────────────────────────────────────
# 12. ADMIN SEED
# ──────────────────────────────────────────────
ADMIN_EMAIL=admin@your-domain.com
ADMIN_PASSWORD=ChangeMe123!

# ──────────────────────────────────────────────
# 13. APP VERSION (dùng cho docker image tag)
# ──────────────────────────────────────────────
APP_VERSION=latest

# ──────────────────────────────────────────────
# 14. SYSTEM MONITORING & ALERTING
# ──────────────────────────────────────────────
# Telegram Bot — Tạo qua BotFather (https://t.me/BotFather)
TELEGRAM_BOT_TOKEN=""
# Danh sách Chat ID nhận cảnh báo (ngăn bằng dấu phẩy, hỗ trợ cá nhân + group)
TELEGRAM_CHAT_IDS=""

# Email nhận cảnh báo (ngăn bằng dấu phẩy)
ALERT_EMAILS="admin@your-domain.com"

# ──────────────────────────────────────────────
# 15. DAILY AUTOMATED BACKUP (Cloudflare R2 / S3)
# ──────────────────────────────────────────────
# Backup chạy vào 3:00 AM mỗi ngày, gửi CẢ 2 kênh:
#   - Telegram Bot (dùng chung token ở mục 14, giới hạn 50MB/file)
#   - Cloudflare R2 / S3 (không giới hạn, cần key bên dưới)
# Nếu S3_ACCESS_KEY để trống → chỉ gửi Telegram.
# Khi có key R2, chỉ cần thêm vào GitHub Secret VPS1_ENV rồi redeploy.
S3_BUCKET="sensa-smart-backups"
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_REGION="auto"
# Cloudflare R2 endpoint: https://<ACCOUNT_ID>.r2.cloudflarestorage.com
# Tìm Account ID ở Cloudflare Dashboard → R2 → Overview
S3_ENDPOINT=""
