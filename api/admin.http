# ==========================================
# ADMIN – Partner, Device Model, Quota, MQTT Config
# ==========================================
# Chạy request "Login Admin" trước để có accessToken
@baseUrl = https://aurathink.ddns.net/api/v1
@adminEmail = vulewenlian94@gmail.com
@adminPassword = Vu31101994@
@companyCode = BKTech
@deviceModelCode = 1001

###
# Login Admin (chạy trước các request bên dưới)
# @name loginAdmin
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
    "identifier": "{{adminEmail}}",
    "password": "{{adminPassword}}"
}

###
# ==========================================
# --- PARTNERS ---
# ==========================================

# Tạo Partner (Công ty)
POST {{baseUrl}}/admin/partners
Authorization: Bearer {{loginAdmin.response.body.data.accessToken}}
Content-Type: application/json

{
    "code": "{{companyCode}}",
    "name": "BKTech Global SmartHome"
}

###
# Lấy danh sách Partner (dropdown)
# @name listPartners
GET {{baseUrl}}/admin/options/partners
Authorization: Bearer {{loginAdmin.response.body.data.accessToken}}

###
# Cập nhật Partner (tên, quota...)
PUT {{baseUrl}}/admin/partners/{{companyCode}}
Authorization: Bearer {{loginAdmin.response.body.data.accessToken}}
Content-Type: application/json

{
    "name": "BKTech Global SmartHome (Updated)",
    "quotas": [
        {
            "deviceModelCode": "{{deviceModelCode}}",
            "quantity": 100
        }
    ]
}

###
# Thống kê sử dụng theo Partner
GET {{baseUrl}}/admin/stats/partners
Authorization: Bearer {{loginAdmin.response.body.data.accessToken}}

###
# ==========================================
# --- DEVICE MODELS ---
# ==========================================

# Tạo Device Model (khuôn mẫu thiết bị)
POST {{baseUrl}}/admin/device-models
Authorization: Bearer {{loginAdmin.response.body.data.accessToken}}
Content-Type: application/json

{
    "code": "{{deviceModelCode}}",
    "name": "Cửa cuốn thông minh WiFi",
    "config": {
        "modelCode": "SHUTTER_DOOR",
        "modelName": "Cửa cuốn thông minh",
        "protocol": "MQTT",
        "entities": [
            {
                "code": "main",
                "name": "Cửa cuốn",
                "domain": "curtain",
                "commandKey": "state",
                "commandSuffix": "set",
                "readOnly": false,
                "sortOrder": 0,
                "attributes": [
                    {
                        "key": "position",
                        "name": "Vị trí (%)",
                        "valueType": "NUMBER",
                        "min": 0, "max": 100, "unit": "%",
                        "readOnly": true
                    },
                    {
                        "key": "travel",
                        "name": "Thời gian di chuyển (ms)",
                        "valueType": "NUMBER",
                        "unit": "ms",
                        "readOnly": true
                    }
                ]
            },
            {
                "code": "child_lock",
                "name": "Khoá trẻ em",
                "domain": "lock",
                "commandKey": "child_lock",
                "commandSuffix": "set",
                "readOnly": false,
                "sortOrder": 1
            },
            {
                "code": "ble_mode",
                "name": "Chế độ BLE",
                "domain": "switch",
                "commandKey": "ble",
                "commandSuffix": "set",
                "readOnly": false,
                "sortOrder": 2
            },
            {
                "code": "config",
                "name": "Cấu hình bảo mật",
                "domain": "config",
                "commandKey": "config",
                "commandSuffix": "set",
                "readOnly": false,
                "sortOrder": 3
            },
            {
                "code": "learn",
                "name": "Học lệnh RF",
                "domain": "rf_learn",
                "commandKey": "learn_cmd",
                "commandSuffix": "set",
                "readOnly": false,
                "sortOrder": 4
            }
        ]
    }
}

###
# Lấy danh sách Device Model (dropdown)
# @name listDeviceModels
GET {{baseUrl}}/admin/options/device-models
Authorization: Bearer {{loginAdmin.response.body.data.accessToken}}

###
# ⚡ Cập nhật Device Model
# Dùng khi model đã tồn tại nhưng cần cập nhật entities
# TODO: Sau khi deploy + chạy add_entity_domains.sql → thêm lại:
#   - ble_mode domain: "switch" (hiện dùng "switch_")
#   - config entity: domain "config"
PUT {{baseUrl}}/admin/device-models/{{deviceModelCode}}
Authorization: Bearer {{loginAdmin.response.body.data.accessToken}}
Content-Type: application/json

{
    "code": "{{deviceModelCode}}",
    "name": "Cửa cuốn thông minh WiFi",
    "config": {
        "modelCode": "SHUTTER_DOOR",
        "modelName": "Cửa cuốn thông minh",
        "protocol": "MQTT",
        "entities": [
            {
                "code": "main",
                "name": "Cửa cuốn",
                "domain": "curtain",
                "commandKey": "state",
                "commandSuffix": "set",
                "readOnly": false,
                "sortOrder": 0,
                "attributes": [
                    {
                        "key": "position",
                        "name": "Vị trí (%)",
                        "valueType": "NUMBER",
                        "min": 0, "max": 100, "unit": "%",
                        "readOnly": true
                    },
                    {
                        "key": "travel",
                        "name": "Thời gian di chuyển (ms)",
                        "valueType": "NUMBER",
                        "unit": "ms",
                        "readOnly": true
                    }
                ]
            },
            {
                "code": "child_lock",
                "name": "Khoá trẻ em",
                "domain": "lock",
                "commandKey": "child_lock",
                "commandSuffix": "set",
                "readOnly": false,
                "sortOrder": 1
            },
            {
                "code": "ble_mode",
                "name": "Chế độ BLE",
                "domain": "switch_",
                "commandKey": "ble",
                "commandSuffix": "set",
                "readOnly": false,
                "sortOrder": 2
            },
            {
                "code": "learn",
                "name": "Học lệnh RF",
                "domain": "button",
                "commandKey": "learn_cmd",
                "commandSuffix": "set",
                "readOnly": false,
                "sortOrder": 4
            }
        ]
    }
}


###
# Danh sách quota (raw)
GET {{baseUrl}}/admin/quotas
Authorization: Bearer {{loginAdmin.response.body.data.accessToken}}

###
# ==========================================
# --- SYSTEM CONFIGS (MQTT & OTP) ---
# ==========================================

# Cấu hình MQTT (Broker) - Set nhanh host/user/pass
POST {{baseUrl}}/admin/configs/mqtt
Authorization: Bearer {{loginAdmin.response.body.data.accessToken}}
Content-Type: application/json

{
    "host": "mqtt://aurathink.ddns.net:1883",
    "user": "admin_mqtt",
    "pass": "password_mqtt"
}

###
# Cập nhật WSS URL (dùng cho App mobile kết nối MQTT qua WebSocket)
PUT {{baseUrl}}/admin/configs
Authorization: Bearer {{loginAdmin.response.body.data.accessToken}}
Content-Type: application/json

{
    "mqttWssUrl": "wss://aurathink.ddns.net/mqtt"
}

###
# Lấy toàn bộ cấu hình hệ thống
GET {{baseUrl}}/admin/configs
Authorization: Bearer {{loginAdmin.response.body.data.accessToken}}

###
# Cập nhật cấu hình hệ thống (MQTT, OTP...)
PUT {{baseUrl}}/admin/configs
Authorization: Bearer {{loginAdmin.response.body.data.accessToken}}
Content-Type: application/json

{
    "mqttHost": "mqtt://aurathink.ddns.net:1883",
    "mqttUser": "admin_mqtt",
    "mqttPass": "password_mqtt",
    "otpExpire": 10
}
