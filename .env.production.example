# ══════════════════════════════════════════════════════════════
# .env.production.example — Dùng khi deploy Production
# ══════════════════════════════════════════════════════════════
# Copy: cp .env.production.example .env
# Áp dụng: docker compose -f docker-compose.prod.yml up -d
#
# ⚠️ THAY TẤT CẢ GIÁ TRỊ "change-me-*" TRƯỚC KHI DÙNG
# Tạo secret: openssl rand -base64 32

# ──────────────────────────────────────────────
# APPLICATION
# ──────────────────────────────────────────────
APP_ENV="production"
APP_NAME="aurathink"
APP_DEBUG=false
APP_LOG_LEVEL="warn"

# ──────────────────────────────────────────────
# HTTP SERVER
# ──────────────────────────────────────────────
HTTP_HOST="0.0.0.0"
HTTP_PORT=3001
HTTP_VERSIONING_ENABLE=true
HTTP_VERSION=1

# ⚠️ Thay bằng domain thật
APP_CORS_ORIGINS="https://your-domain.com,https://app.your-domain.com"

# ──────────────────────────────────────────────
# MICROSERVICE PORTS
# ──────────────────────────────────────────────
SOCKET_GATEWAY_PORT=3002
IOT_GATEWAY_PORT=3003
WORKER_SERVICE_PORT=3004

# ──────────────────────────────────────────────
# AUTHENTICATION & JWT
# ──────────────────────────────────────────────
# Tạo: openssl rand -base64 32
AUTH_ACCESS_TOKEN_SECRET="change-me-use-openssl-rand-base64-32"
AUTH_REFRESH_TOKEN_SECRET="change-me-use-openssl-rand-base64-32"
AUTH_ACCESS_TOKEN_EXP="1d"
AUTH_REFRESH_TOKEN_EXP="7d"

# ──────────────────────────────────────────────
# DATABASE — host = "postgres" (service name)
# ──────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong-db-password
POSTGRES_DB=aurathink
# DATABASE_URL được override bởi docker-compose.prod.yml
DATABASE_URL="postgresql://postgres:change-me-strong-db-password@postgres:5432/aurathink?schema=public"

# ──────────────────────────────────────────────
# REDIS — host = "redis" (service name)
# ──────────────────────────────────────────────
REDIS_HOST="redis"
REDIS_PORT=6379
REDIS_USERNAME=default
REDIS_PASSWORD="change-me-redis-password"
REDIS_ENABLE_TLS=false

# ──────────────────────────────────────────────
# MQTT (EMQX) — host = "emqx" (service name)
# ──────────────────────────────────────────────
MQTT_HOST=mqtt://emqx
MQTT_PORT=1883
MQTT_USER=smarthome-server
MQTT_PASS=change-me-mqtt-password

# ──────────────────────────────────────────────
# EMQX Dashboard
# ──────────────────────────────────────────────
EMQX_DASHBOARD_USER=admin
EMQX_DASHBOARD_PASS=change-me-dashboard-password

# ──────────────────────────────────────────────
# MAIL (SMTP)
# ──────────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FROM="Smart Home Support <your-email@gmail.com>"

# ──────────────────────────────────────────────
# SSL
# ──────────────────────────────────────────────
SSL_CERT_PATH=./deploy/docker/ssl

# ──────────────────────────────────────────────
# SENTRY (tuỳ chọn)
# ──────────────────────────────────────────────
SENTRY_DSN=""

# ──────────────────────────────────────────────
# ADMIN SEED
# ──────────────────────────────────────────────
ADMIN_EMAIL=admin@your-domain.com
ADMIN_PASSWORD=change-me-admin-password

# ──────────────────────────────────────────────
# APP VERSION (docker image tag)
# ──────────────────────────────────────────────
APP_VERSION=latest
